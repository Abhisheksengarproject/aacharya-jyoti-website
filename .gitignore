# ── Secrets — NEVER commit these ──────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Dependencies ───────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ── Build output ───────────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/

# ── Logs ───────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS files ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Large binary/installer files — should never be in source code ──
*.exe
*.dmg
*.zip
*.tar.gz
*.msi
*.pkg
